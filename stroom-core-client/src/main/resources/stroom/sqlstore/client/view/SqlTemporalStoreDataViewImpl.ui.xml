<!DOCTYPE ui:UiBinder SYSTEM "http://dl.google.com/gwt/DTD/xhtml.ent">
<ui:UiBinder xmlns:ui="urn:ui:com.google.gwt.uibinder"
             xmlns:g="urn:import:com.google.gwt.user.client.ui">
    <g:HTMLPanel styleName="max flex-layout-container flex-layout-column">
        <g:HorizontalPanel styleName="form-group margin-10 flex-layout-item flex-layout-row-item">
            <g:Label text="Query:" styleName="margin-10"/>
            <g:TextBox ui:field="query" styleName="form-control" width="600px"/>
            <g:Button ui:field="run" text="Run" styleName="Button margin-left-10"/>
            <g:Button ui:field="stop" text="Stop" styleName="Button margin-left-10"/>
        </g:HorizontalPanel>
        <g:SimplePanel ui:field="tableContainer" styleName="max flex-layout-item flex-layout-expand"/>
    </g:HTMLPanel>
</ui:UiBinder>
