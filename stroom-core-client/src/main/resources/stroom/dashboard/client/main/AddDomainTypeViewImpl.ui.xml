<!DOCTYPE ui:UiBinder SYSTEM "http://dl.google.com/gwt/DTD/xhtml.ent">
<ui:UiBinder xmlns:ui="urn:ui:com.google.gwt.uibinder"
             xmlns:g="urn:import:com.google.gwt.user.client.ui"
             xmlns:l="urn:import:stroom.item.client"
             xmlns:form="urn:import:stroom.widget.form.client">
    <g:FlowPanel styleName="max form-padding form">
        <form:FormGroup identity="addDomainTypeClass" label="Host">
            <l:SelectionBox ui:field="classPart" addStyleNames="w-100"/>
        </form:FormGroup>
        <form:FormGroup identity="addDomainTypeAttribute" label="Attribute Type">
            <l:SelectionBox ui:field="attributePart" addStyleNames="w-100"/>
        </form:FormGroup>
    </g:FlowPanel>
</ui:UiBinder>
