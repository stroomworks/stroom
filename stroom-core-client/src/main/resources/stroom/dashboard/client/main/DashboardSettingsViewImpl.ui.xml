<!DOCTYPE ui:UiBinder SYSTEM "http://dl.google.com/gwt/DTD/xhtml.ent">
<ui:UiBinder xmlns:ui="urn:ui:com.google.gwt.uibinder"
             xmlns:g="urn:import:com.google.gwt.user.client.ui"
             xmlns:l="urn:import:stroom.item.client"
             xmlns:form="urn:import:stroom.widget.form.client">
    <g:FlowPanel styleName="max form-padding form dashboard-settings">
        <form:FormGroup identity="dashboardSettingsType" label="Type">
            <g:FlowPanel addStyleNames="dock-container-horizontal">
                <l:SelectionBox ui:field="domainTypeClassPart" addStyleNames="dock-max w-50"/>
                <l:SelectionBox ui:field="domainTypeAttributePart" addStyleNames="dock-max w-50"/>
            </g:FlowPanel>
        </form:FormGroup>
    </g:FlowPanel>
</ui:UiBinder>
