<!DOCTYPE ui:UiBinder SYSTEM "http://dl.google.com/gwt/DTD/xhtml.ent">
<ui:UiBinder xmlns:ui="urn:ui:com.google.gwt.uibinder"
             xmlns:g="urn:import:com.google.gwt.user.client.ui"
             xmlns:b="urn:import:stroom.widget.button.client">

    <ui:style>
        .errorLabel {
            margin: 0px 8px 8px 8px;
            padding: 8px 12px;
            border: 1px solid var(--error);
            border-radius: 4px;
            background-color: rgba(220, 53, 69, 0.15);
            color: var(--error);
            font-weight: 500;
            white-space: pre-wrap;
            word-break: break-word;
        }
    </ui:style>

    <g:FlowPanel styleName="max dock-container-vertical">
        <g:FlowPanel styleName="dock-min dock-container-horizontal align-center form-padding input-row">
            <g:Label text="Query:" styleName="dock-min"/>
            <g:TextBox ui:field="query" styleName="dock-max" />
            <b:InlineSvgButton ui:field="run" title="Run" addStyleNames="QueryButtons-button play dock-min"/>
            <b:InlineSvgButton ui:field="stop" title="Stop" addStyleNames="QueryButtons-button stop dock-min"/>
        </g:FlowPanel>
        <g:Label ui:field="errorLabel" styleName="{style.errorLabel}" visible="false"/>
        <g:SimplePanel ui:field="tableContainer" styleName="max dock-max"/>
    </g:FlowPanel>
</ui:UiBinder>
