<ui:UiBinder xmlns:ui="urn:ui:com.google.gwt.uibinder"
             xmlns:g="urn:import:com.google.gwt.user.client.ui">
    <g:DockLayoutPanel unit='PX' styleName="max" ui:field="mainDockPanel">
        <!-- Split layout for map above and timeline below -->
        <g:center>
            <g:ThinSplitLayoutPanel vSplits="0.9" styleName="max">
                <!-- Top section: The SVG map -->
                <g:north size="200">
                    <g:SimplePanel ui:field="mapPanel" addStyleNames="max" />
                </g:north>
                <!-- Bottom section: Timeline -->
                <g:center>
                    <g:SimplePanel ui:field="timelinePanel" addStyleNames="max" />
                </g:center>
            </g:ThinSplitLayoutPanel>
        </g:center>
    </g:DockLayoutPanel>
</ui:UiBinder>
