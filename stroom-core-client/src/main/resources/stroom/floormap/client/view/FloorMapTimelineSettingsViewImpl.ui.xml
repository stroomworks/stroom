<!DOCTYPE ui:UiBinder SYSTEM "http://dl.google.com/gwt/DTD/xhtml.ent">
<ui:UiBinder xmlns:ui="urn:ui:com.google.gwt.uibinder"
             xmlns:g="urn:import:com.google.gwt.user.client.ui"
             xmlns:datetimebox="urn:import:stroom.widget.datepicker.client"
             xmlns:l="urn:import:stroom.item.client">

    <g:FlowPanel addStyleNames="stroom-floormap-timeline-settings-popup">
        <!-- Playback Speed -->
        <g:FlowPanel addStyleNames="stroom-floormap-timeline-settings-row">
            <g:Label text="Playback Speed" addStyleNames="stroom-floormap-timeline-settings-label" />
            <l:SelectionBox ui:field="speedSelectionBox" addStyleNames="stroom-floormap-timeline-settings-speed-box" />
        </g:FlowPanel>

        <!-- Date Range -->
        <g:FlowPanel addStyleNames="stroom-floormap-timeline-settings-row">
            <g:Label text="Start Date" addStyleNames="stroom-floormap-timeline-settings-label" />
            <datetimebox:DateTimeBox ui:field="startDateTimeBox" addStyleNames="stroom-floormap-timeline-settings-date-box" />
        </g:FlowPanel>
        <g:FlowPanel addStyleNames="stroom-floormap-timeline-settings-row">
            <g:Label text="End Date" addStyleNames="stroom-floormap-timeline-settings-label" />
            <datetimebox:DateTimeBox ui:field="endDateTimeBox" addStyleNames="stroom-floormap-timeline-settings-date-box" />
        </g:FlowPanel>
    </g:FlowPanel>
</ui:UiBinder>
