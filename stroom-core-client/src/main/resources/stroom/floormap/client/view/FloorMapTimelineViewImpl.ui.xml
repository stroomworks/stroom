<!DOCTYPE ui:UiBinder SYSTEM "http://dl.google.com/gwt/DTD/xhtml.ent">
<ui:UiBinder xmlns:ui="urn:ui:com.google.gwt.uibinder"
             xmlns:g="urn:import:com.google.gwt.user.client.ui"
             xmlns:datetimebox="urn:import:stroom.widget.datepicker.client">

    <g:FlowPanel addStyleNames="stroom-floormap-timeline-container max">
        <!-- Labels Above the timeline -->
        <g:FlowPanel addStyleNames="stroom-floormap-timeline-label-row">
            <datetimebox:DateTimeBox ui:field="startDateTimeBox" addStyleNames="timeline-date-box" />
            <datetimebox:DateTimeBox ui:field="endDateTimeBox" addStyleNames="timeline-date-box" />
        </g:FlowPanel>

        <!-- The Bar -->
        <g:FlowPanel ui:field="outerBar" addStyleNames="stroom-floormap-timeline-outer-bar">
            <g:FlowPanel ui:field="innerBar" addStyleNames="stroom-floormap-timeline-inner-bar" />
            <g:FlowPanel ui:field="handle" addStyleNames="stroom-floormap-timeline-handle" />
            <g:FlowPanel ui:field="markerLayer" addStyleNames="max" />
        </g:FlowPanel>
    </g:FlowPanel>
</ui:UiBinder>
