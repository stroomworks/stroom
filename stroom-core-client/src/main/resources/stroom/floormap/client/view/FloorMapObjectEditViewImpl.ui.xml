<ui:UiBinder xmlns:ui="urn:ui:com.google.gwt.uibinder"
             xmlns:g="urn:import:com.google.gwt.user.client.ui"
             xmlns:form="urn:import:stroom.widget.form.client"
             xmlns:datetimebox="urn:import:stroom.widget.datepicker.client">
    <g:FlowPanel styleName="max dock-container-vertical form">
        <g:Label ui:field="objectLabel" addStyleNames="stroom-floormap-active-object-label" />
        
        <!-- TOP: Historical Shards Grid -->
        <g:FlowPanel addStyleNames="max dock-container-vertical flex-grow">
            <g:SimplePanel ui:field="toolbarContainer" />
            <g:SimplePanel ui:field="gridContainer" addStyleNames="stroom-floormap-background-grid flex-grow max" />
        </g:FlowPanel>

        <!-- BOTTOM: Location/Time Editor Form (placed under the grid) -->
        <g:FlowPanel addStyleNames="dock-container-vertical stroom-floormap-edit-form-panel">
            <g:HTML styleName="stroom-label-header">Edit Temporal State</g:HTML>
            <form:FormGroup label="Effective From Time">
                <datetimebox:DateTimeBox ui:field="effectiveTimeBox" addStyleNames="timeline-date-box wide-control" />
            </form:FormGroup>

            <form:FormGroup label="X Coordinate">
                <g:TextBox ui:field="xBox" addStyleNames="stroom-control wide-control" />
            </form:FormGroup>

            <form:FormGroup label="Y Coordinate">
                <g:TextBox ui:field="yBox" addStyleNames="stroom-control wide-control" />
            </form:FormGroup>

            <g:FlowPanel addStyleNames="stroom-floormap-actions-group">
                <g:Button ui:field="saveBtn" text="Commit Location State" addStyleNames="stroom-button stroom-button-blue" />
            </g:FlowPanel>
        </g:FlowPanel>
    </g:FlowPanel>
</ui:UiBinder>
